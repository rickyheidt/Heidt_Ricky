# SKINZ Environment Variables
# Copy this file to .env.local for local development

# ── GHIN API (USGA) ──────────────────────────────────────────────────────────
# Required for real handicap sync.
# Apply for access at: https://www.usga.org/content/usga/home-page/handicapping/ghin.html
# Once approved, paste your token here and add it to Vercel environment variables.
GHIN_API_TOKEN=your_ghin_api_token_here
